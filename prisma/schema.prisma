// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  Normal
  Admin
  Moderator
  ContentWriter
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  role          UserRole @default(Normal)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  modifiedAt    DateTime @updatedAt
}

model Device {
  id         String  @id
  name       String
  brand      String
  category   String
  price      String
  rating     Float   @default(0)
  imageColor String
  isNew      Boolean @default(false)
  isTopRated Boolean @default(false)
  status     String
  specs      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  blogs     Blog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id           Int           @id @default(autoincrement())
  title        String
  excerpt      String?
  date         String
  readTime     String?
  author       String
  category     String
  categoryId   Int?
  blogCategory BlogCategory? @relation(fields: [categoryId], references: [id])
  color        String?
  image        String?
  content      String
  status       String        @default("published")
  seo          Json?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

