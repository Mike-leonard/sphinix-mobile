// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  Normal
  Admin
  Moderator
  ContentWriter
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  role          UserRole @default(Normal)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  modifiedAt    DateTime @updatedAt
}

model DeviceBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String?  @unique
  devices   Device[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id          String       @id
  name        String
  brand       String
  brandId     Int?
  deviceBrand DeviceBrand? @relation(fields: [brandId], references: [id])
  price       String
  rating      Float        @default(0)
  imageColor  String
  isNew       Boolean      @default(false)
  isTopRated  Boolean      @default(false)
  status      String
  specs       Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceFilter {
  id            String   @id
  title         String
  attributeSlug String
  options       String[]
  order         Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeviceGroup {
  id         Int               @id @default(autoincrement())
  name       String            @unique
  order      Int               @default(0)
  attributes DeviceAttribute[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DeviceAttribute {
  id          String       @id
  name        String
  slug        String       @unique
  terms       String[]
  group       String       @default("General")
  groupId     Int?
  deviceGroup DeviceGroup? @relation(fields: [groupId], references: [id])
  placeholder String?
  order       Int          @default(0)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RatingBar {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?  @default("")
  defaultValue Int      @default(3)
  order        Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  blogs     Blog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id           Int           @id @default(autoincrement())
  title        String
  excerpt      String?
  date         String
  readTime     String?
  author       String
  category     String
  categoryId   Int?
  blogCategory BlogCategory? @relation(fields: [categoryId], references: [id])
  color        String?
  image        String?
  content      String
  status       String        @default("published")
  seo          Json?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SiteSettings {
  id             Int      @id @default(1)
  version        Int      @default(1)
  seo            Json?
  typography     Json?
  appearance     Json?
  analytics      Json?
  advertisements Json?
  comments       Json?
  localization   Json?
  maintenance    Json?
  socialMedia    Json?
  media          Json?
  security       Json?
  ai             Json?
  recaptcha      Json?
  backups        Json?

  updatedAt      DateTime @updatedAt
}
